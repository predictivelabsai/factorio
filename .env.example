DB_URL=postgresql://user:pass@localhost:5432/factorfinance
APP_SECRET=change-me-to-a-random-string
APP_ENV=dev
PORT=5055

# AI — Grok via x.ai (powers /app/triage and /app/assistant). Optional:
# the assistants degrade gracefully when XAI_API_KEY is unset.
XAI_API_KEY=
XAI_MODEL=grok-4.3
XAI_BASE_URL=https://api.x.ai/v1
